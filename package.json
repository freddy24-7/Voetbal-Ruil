{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "bun run build:backend && bun run build:frontend",
    "build:frontend": "vite build",
    "build:backend": "tsc -p backend/tsconfig.json",
    "preview": "vite preview",
    "test:prod": "bun run build && bun run preview",
    "dev:backend": "tsc -p backend/tsconfig.json && node backend/dist/main.js",
    "seed": "tsc -p backend/tsconfig.json && node backend/dist/seed.js",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "postinstall": "find node_modules -mindepth 3 -maxdepth 3 -type d -name 'uuid' -path '*/node_modules/*/node_modules/uuid' | xargs rm -rf"
  },
